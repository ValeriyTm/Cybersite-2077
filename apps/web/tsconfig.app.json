{
  "compilerOptions": {
    // Создаем файл кэша. Благодаря ему при следующей проверке TypeScript будет проверять только измененные файлы:
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "target": "ESNext",
    "useDefineForClassFields": true, //Заставляет поля в классах работать по стандарту ECMAScript (важно для корректного поведения логики в некоторых библиотеках).
    "lib": ["ESNext", "DOM", "DOM.Iterable"], // Говорит TS, какие типы «знать» по умолчанию.
    "module": "ESNext", //Использует самый современный формат модулей.
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "cypress"
    ], //Добавляет поддержку специфических типов Vite, Vitest и testing-library
    "skipLibCheck": true, //Не проверять типы внутри node_modules

    // В monorepo мы импортируем код из ../../packages,
    // поэтому rootDir должен покрывать и apps/web и packages/*.
    "rootDir": "../..",

    "baseUrl": ".", //Корень для отсчета путей — папка apps/web.
    "paths": {
      "@/*": ["./src/*"], //Позволяет писать короткие импорты import ... from '@/shared/ui', вместо того чтобы считать точки ../../../.
      //Для работы с Zod:
      "@repo/validation": ["../../packages/validation/index.ts"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler", //Режим, созданный специально для Vite/Webpack. Он разрешает импорты так же, как это делает сам сборщик.
    "allowImportingTsExtensions": true, //Разрешает импортировать файлы с расширением .ts (нужно для работы в связке с noEmit).
    "verbatimModuleSyntax": true, //Следит за тем, чтобы import type использовался строго для типов.
    "moduleDetection": "force", //Заставляет TS считать каждый файл отдельным модулем, даже если в нем нет import/export.
    "noEmit": true, //TypeScript здесь только проверяет ошибки. За превращение кода в JavaScript отвечает сам Vite
    "jsx": "react-jsx", //Включает поддержку React 17+ (позволяет не писать import React from 'react' в каждом файле).

    /* Linting */
    "strict": true, //Максимальный уровень контроля типов.
    //Выдает ошибки, если есть неиспользуемые переменные или аргументы:
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "noFallthroughCasesInSwitch": true //Защита от багов в switch, когда забыл написать break.
  },
  //Проверять только файлы внутри папки src + Vite env types:
  "include": [
    "src",
    "vite-env.d.ts",
    "../../packages/validation/**/*.ts",
    "cypress"
  ]
}
